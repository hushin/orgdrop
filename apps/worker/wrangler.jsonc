{
	"name": "orgdrop",
	"compatibility_date": "2025-11-22",
	"assets": {
		"directory": "../frontend/dist",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*", "/auth/*"]
	},
	"main": "src/index.ts",
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "DROPBOX_CACHE",
			"id": "a30b3ff828464016aaf55d9696c28783"
		}
	]
}
