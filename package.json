{
    "name": "orgdrop-monorepo",
    "private": true,
    "scripts": {
        "dev": "pnpm --parallel --filter \"./apps/*\" dev",
        "build": "pnpm -r build",
        "build:web": "pnpm --filter @orgdrop/domain build && pnpm --filter orgdrop build",
        "lint": "pnpm -r lint"
    },
    "devDependencies": {
        "typescript": "~5.9.3"
    }
}