{
	"name": "orgdrop-monorepo",
	"private": true,
	"scripts": {
		"dev": "pnpm --parallel -r dev",
		"build": "pnpm -r build",
		"deploy": "npx wrangler deploy --config apps/worker/wrangler.jsonc",
		"upload-version": "npx wrangler versions upload --config apps/worker/wrangler.jsonc",
		"lint": "pnpm -r lint",
		"format": "biome format --write .",
		"check": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.7",
		"lefthook": "^2.0.4",
		"typescript": "~5.9.3"
	}
}
